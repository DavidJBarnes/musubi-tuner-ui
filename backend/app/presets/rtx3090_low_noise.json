{
  "name": "RTX 3090 — Low Noise (timesteps 0-900)",
  "description": "For WAN 2.2 I2V low noise model. Trains on timesteps 0-900 with lower learning rate.",
  "training_args": {
    "task": "i2v-A14B",
    "network_dim": 16,
    "network_alpha": 16,
    "loraplus_lr_ratio": 4,
    "timestep_sampling": "shift",
    "discrete_flow_shift": 5.0,
    "min_timestep": 0,
    "max_timestep": 900,
    "preserve_distribution_shape": true,
    "optimizer_type": "adamw8bit",
    "learning_rate": 1e-4,
    "lr_scheduler": "cosine",
    "max_train_epochs": 20,
    "save_every_n_epochs": 2,
    "mixed_precision": "fp16",
    "fp8_base": true,
    "fp8_scaled": true,
    "gradient_checkpointing": true,
    "blocks_to_swap": 20,
    "seed": 42
  }
}
